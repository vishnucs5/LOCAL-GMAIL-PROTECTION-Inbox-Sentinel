APP_NAME=Inbox Sentinel
APP_ENVIRONMENT=development
HOST=127.0.0.1
PORT=8000
DATABASE_URL=sqlite:///./spam_detector.db
ENABLE_SCHEDULER=false

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

APP_ENCRYPTION_KEY=replace-with-a-long-random-secret
SESSION_SECRET=replace-with-a-different-random-secret

AI_API_KEY=your-ai-api-key
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini
AI_TIMEOUT_SECONDS=30
GMAIL_TIMEOUT_SECONDS=5

DEFAULT_POLL_INTERVAL_SECONDS=60
DEFAULT_SPAM_THRESHOLD=0.85
DEFAULT_GMAIL_LABEL_NAME=AI_SPAM_REVIEW
DEFAULT_MAX_BODY_CHARS=8192
INITIAL_BACKFILL_LIMIT=10
